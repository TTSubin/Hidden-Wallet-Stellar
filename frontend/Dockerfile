FROM node:22-alpine AS builder

WORKDIR /app

ARG VITE_API_URL=/api
ARG VITE_STELLAR_NETWORK=TESTNET
ARG VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
ARG VITE_STELLAR_USDC_ASSET_CODE=USDC
ARG VITE_STELLAR_USDC_ASSET_ISSUER=
ARG VITE_STELLAR_USDC_DECIMALS=7
ARG VITE_GAIAN_API_URL=
ARG VITE_GAIAN_API_KEY=

ENV VITE_API_URL=$VITE_API_URL
ENV VITE_STELLAR_NETWORK=$VITE_STELLAR_NETWORK
ENV VITE_STELLAR_HORIZON_URL=$VITE_STELLAR_HORIZON_URL
ENV VITE_STELLAR_USDC_ASSET_CODE=$VITE_STELLAR_USDC_ASSET_CODE
ENV VITE_STELLAR_USDC_ASSET_ISSUER=$VITE_STELLAR_USDC_ASSET_ISSUER
ENV VITE_STELLAR_USDC_DECIMALS=$VITE_STELLAR_USDC_DECIMALS
ENV VITE_GAIAN_API_URL=$VITE_GAIAN_API_URL
ENV VITE_GAIAN_API_KEY=$VITE_GAIAN_API_KEY

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80
